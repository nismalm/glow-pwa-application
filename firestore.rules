rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // users/{mobile} — mobile number is the client identifier.
    // Any authenticated session (anonymous) can read/write their own document.
    match /users/{clientId} {
      allow read, write: if request.auth != null;

      match /dailyLogs/{date} {
        allow read, write: if request.auth != null
          && date.matches('^\\d{4}-\\d{2}-\\d{2}$');
      }

      match /streaks/{doc} {
        allow read, write: if request.auth != null;
      }

      match /tasks/{taskId} {
        allow read, write: if request.auth != null;
      }

      match /weights/{date} {
        allow read, write: if request.auth != null
          && date.matches('^\\d{4}-\\d{2}-\\d{2}$');
      }
    }
  }
}
